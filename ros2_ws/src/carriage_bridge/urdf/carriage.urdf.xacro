<?xml version="1.0"?>
<robot name="welding_carriage" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Параметры из паспорта -->
  <xacro:property name="body_l" value="0.265"/>
  <xacro:property name="body_w" value="0.160"/>
  <xacro:property name="body_h" value="0.245"/>
  <xacro:property name="wheel_r" value="0.025"/>

  <!-- Базовое звено -->
  <link name="base_link">
    <visual>
      <geometry><box size="${body_l} ${body_w} ${body_h}"/></geometry>
      <material name="dark_gray"><color rgba="0.2 0.2 0.2 1"/></material>
    </visual>
    <collision>
      <geometry><box size="${body_l} ${body_w} ${body_h}"/></geometry>
    </collision>
    <inertial>
      <mass value="8.0"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05"/>
    </inertial>
  </link>

  <!-- Каретка (движение вдоль X) -->
  <link name="carriage_link">
    <visual>
      <geometry><box size="0.05 0.14 0.02"/></geometry>
      <material name="blue"><color rgba="0.1 0.4 0.9 1"/></material>
    </visual>
  </link>
  <joint name="carriage_joint" type="prismatic">
    <parent link="base_link"/>
    <child link="carriage_link"/>
    <axis xyz="1 0 0"/>
    <limit lower="0" upper="5.0" effort="50" velocity="0.05"/>
    <origin xyz="0 0 0.13"/>
  </joint>

  <!-- Осциллятор (вращение вокруг Z) -->
  <link name="oscillator_link">
    <visual>
      <geometry><cylinder radius="0.015" length="0.08"/></geometry>
      <material name="orange"><color rgba="0.9 0.5 0.1 1"/></material>
    </visual>
  </link>
  <joint name="oscillator_joint" type="revolute">
    <parent link="carriage_link"/>
    <child link="oscillator_link"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.297" upper="0.297" effort="10" velocity="0.35"/>
    <origin xyz="0 0 0.05"/>
  </joint>

  <!-- Горелка -->
  <link name="torch_link">
    <visual>
      <geometry><cylinder radius="0.008" length="0.12"/></geometry>
      <material name="silver"><color rgba="0.8 0.8 0.8 1"/></material>
    </visual>
  </link>
  <joint name="torch_joint" type="fixed">
    <parent link="oscillator_link"/>
    <child link="torch_link"/>
    <origin xyz="0 0 -0.10" rpy="0 0.3 0"/>
  </joint>

</robot>
